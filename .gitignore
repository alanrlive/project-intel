# ── Environment ───────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Claude Code (contains local usernames and allowed command history) ────────
.claude/

# ── Python backend ────────────────────────────────────────────────────────────
backend/.venv/
backend/__pycache__/
backend/**/__pycache__/
