backend/**/*.pyo
backend/*.egg-info/

# ── Backend data (database, uploads, logs) ────────────────────────────────────
backend/data/
backend/logs/
backend/uvicorn.log

# ── Node / frontend ───────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/

# ── Rust / Tauri build artifacts ──────────────────────────────────────────────
frontend/src-tauri/target/

# ── Backups ───────────────────────────────────────────────────────────────────
backups/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
