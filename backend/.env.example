# Copy this file to .env and edit as needed
# .env is gitignored — never commit your actual .env

PROJECT_NAME=My Project

# Ollama (default: local install)
OLLAMA_BASE_URL=http://localhost:11434

# Model assignments (must be pulled via `ollama pull <model>`)
LLM_EXTRACTION=mistral-nemo:latest
LLM_QA=llama3.1:latest
LLM_REASONING=deepseek-r1:latest

# Daily briefing schedule
BRIEFING_HOUR=9
BRIEFING_MINUTE=0
